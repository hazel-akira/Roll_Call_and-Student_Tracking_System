APP_NAME="Roll Call API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=roll_call
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Generate with: php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
JWT_SECRET=
JWT_ISSUER=http://127.0.0.1:8000
JWT_TTL=3600
JWT_REFRESH_TTL=1209600
AUTH_DEFAULT_ROLE_SLUG=teacher
# Set true to let new Microsoft sign-ins use the app immediately without admin approval
AUTH_AUTO_ACTIVATE_SSO_USERS=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_NAME="Platform Administrator"
# Comma-separated teacher email to school code pairs, e.g. teacher@school.com:PS,coach@school.com:PGS
SEED_TEACHER_SCHOOL_ASSIGNMENTS=
# School code used when seeding teachers that have no school_user rows yet
SEED_DEFAULT_TEACHER_SCHOOL=PS

MICROSOFT_CLIENT_ID=
# Required for Filament /admin and /teacher Microsoft login (Web platform in Entra)
MICROSOFT_CLIENT_SECRET=
# Set false to hide Microsoft SSO on Filament panels (/admin, /teacher)
MICROSOFT_SSO_ENABLED=true
# Backend OAuth callback for Filament login (add as Web redirect URI in Entra)
MICROSOFT_REDIRECT_URI=
# Optional if MICROSOFT_ALLOWED_TENANT_IDS contains a single tenant ID
MICROSOFT_TENANT_ID=
# Comma-separated Azure AD tenant IDs allowed to sign in (recommended for single-tenant apps)
MICROSOFT_ALLOWED_TENANT_IDS=
MICROSOFT_ALLOWED_DOMAINS=
# Use your tenant-specific JWKS URL for single-tenant apps (not /common)
MICROSOFT_JWKS_URL=https://login.microsoftonline.com/YOUR_TENANT_ID/discovery/v2.0/keys
MICROSOFT_ISSUER_PREFIX=https://login.microsoftonline.com

DYNAMICS_ENABLED=true
DYNAMICS_BASE_URL=https://your-org.crm4.dynamics.com
DYNAMICS_TENANT_ID=
DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=
DYNAMICS_SCOPE=
DYNAMICS_ATTENDANCE_ENDPOINT=/attendance-sync
DYNAMICS_TIMEOUT=15
