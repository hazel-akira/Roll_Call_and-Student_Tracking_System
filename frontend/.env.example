NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=
# Required for single-tenant Entra apps — must match MICROSOFT_ALLOWED_TENANT_IDS in backend
NEXT_PUBLIC_MICROSOFT_TENANT_ID=
NEXT_PUBLIC_MICROSOFT_AUTHORITY=https://login.microsoftonline.com/YOUR_TENANT_ID
NEXT_PUBLIC_MICROSOFT_REDIRECT_URI=http://localhost:3000/callback
# Optional: comma-separated LAN IPs for Next.js dev HMR (e.g. 192.168.1.10)
NEXT_PUBLIC_DEV_ORIGINS=
